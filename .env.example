# Emby Wrapped Environment Configuration
# Copy to .env and fill in values

# Required: Emby server URL (include protocol and port)
EMBY_URL=http://your-emby-server:8096

# Required: Emby Admin API key
EMBY_API_KEY=your_api_key_here

# Optional: TMDB API key for enhanced poster images
# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=


# Optional: Seerr/Overseerr/Jellyseerr base URL for community request stats card
# Example: http://your-seer-server:5055
SEERR_URL=

# Optional: Seerr/Overseerr/Jellyseerr API key (required if SEER_URL is set)
SEERR_API_KEY=

# Optional: Tracearr base URL + public API key (trr_pub_*)
# When both are set, playback history is sourced from Tracearr instead of Emby Playback Reporting
TRACEARR_URL=
TRACEARR_API_KEY=
# Optional: Map old Tracearr usernames to current Emby usernames (for renamed accounts)
# Format: oldname1:newname1,oldname2:newname2 (case-insensitive)
TRACEARR_USERNAME_ALIASES=

# Optional: Public URL for share links (defaults to request origin)
PUBLIC_URL=https://wrapped.example.com

# Optional: Cache TTL in seconds (default: 86400 = 24 hours)
CACHE_TTL=86400

# Optional: Analytics script (e.g. Umami, Plausible)
# Example: <script defer src="https://cloud.umami.is/script.js" data-website-id="your-id"></script>
ANALYTICS_SCRIPT=

# Optional: User ID for filtering media library items
# Use this to filter out NSFW content by specifying a restricted user's ID
# Only items accessible to this user will be displayed in stats
# Leave empty to use each user's own library permissions
FILTER_USER_ID=
